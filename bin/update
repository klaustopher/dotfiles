#!/usr/bin/env zsh
autoload -Uz colors && colors

has_cmd() { command -v "$1" &>/dev/null }

section() {
  print -- "\n${fg_bold[blue]}┌─────────────────────────────────────────${reset_color}"
  print -- "${fg_bold[blue]}│${reset_color} ${fg_bold[white]}$*${reset_color}"
  print -- "${fg_bold[blue]}└─────────────────────────────────────────${reset_color}"
}

skip() {
  print -- "  ${fg[yellow]}⚠ skipped: $*${reset_color}"
}

# ── Dotfiles ──────────────────────────────────────────────────────────────────
section "Updating .dotfiles \uf1d3 repo"
pushd ~/.dotfiles >/dev/null
git pull origin main
git submodule update --init --recursive
popd >/dev/null

# ── macOS ─────────────────────────────────────────────────────────────────────
if [[ $(uname) == "Darwin" ]]; then
  section "Installing \ue711 Software Updates"
  sudo softwareupdate -i -a

  section "Updating Mac App Store Apps"
  if has_cmd mas; then
    mas outdated
    mas upgrade
  else
    skip "mas not installed"
  fi

  section "Updating \ue0b2 Homebrew Packages"
  if has_cmd brew; then
    # Accept Xcode license if needed to avoid issues with brew update/upgrade
    sudo xcodebuild -license accept

    brew update
    brew upgrade
    brew bundle --file=~/.dotfiles/packages/Brewfile
    brew cleanup -s
  else
    skip "brew not installed"
  fi

# ── Arch Linux ────────────────────────────────────────────────────────────────
elif [[ $(uname) == "Linux" ]]; then
  section "Updating System Packages"
  if has_cmd paru; then
    paru -Syu
  elif has_cmd pacman; then
    sudo pacman -Syu
  else
    skip "no known package manager found (expected paru or pacman)"
  fi
fi

# ── Rubygems ──────────────────────────────────────────────────────────────────
if has_cmd gem; then
  section "Updating \ue739 Rubygems ($(ruby --version | cut -d' ' -f2))"
  gem update --system
else
  section "Rubygems"
  skip "gem not installed"
fi

# ── Editors ───────────────────────────────────────────────────────────────────
if has_cmd code; then
  section "Updating \udb82\ude1e VS Code Extensions"
  code --list-extensions | xargs -I{} code --install-extension {} --force
fi

if has_cmd nvim; then
  section "Updating \ue6ae LazyVim Plugins"
  nvim --headless "+Lazy! sync" +qa
fi

print -- "\n${fg_bold[green]}✓ Done.${reset_color}\n"
