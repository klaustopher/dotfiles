{
  // No telemetry
  "telemetry.enableTelemetry": false,
  "telemetry.enableCrashReporter": false,
  "telemetry.telemetryLevel": "off",
  // Use the amazing Font everybody loves
  "editor.fontFamily": "'FantasqueSansM Nerd Font', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "workbench.colorTheme": "Nightfox",
  "window.autoDetectColorScheme": true,
  "editor.tabSize": 2,
  "files.trimTrailingWhitespace": true,
  "editor.rulers": [
    120
  ],
  "editor.formatOnSave": true,
  "workbench.startupEditor": "newUntitledFile",
  "editor.dragAndDrop": false,
  "explorer.confirmDelete": false,
  "editor.minimap.enabled": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "editor.suggest.filterGraceful": false,
  "editor.largeFileOptimizations": false,
  "security.workspace.trust.untrustedFiles": "open",
  "editor.guides.indentation": true,
  "files.insertFinalNewline": true,
  "git.confirmSync": false,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "workbench.preferredDarkColorTheme": "Nightfox",
  "workbench.preferredLightColorTheme": "Dayfox",
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
  },
  "git.openRepositoryInParentFolders": "always",
  "workbench.settings.editor": "json",
  // Markdown
  "markdown.styles": [
    "https://cdn.jsdelivr.net/gh/dhdhagar/vscode-md-preview-light/style.min.css",
  ],
  // Ruby Settings
  "[ruby]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.insertSpaces": true,
    "editor.semanticHighlighting.enabled": true,
    "editor.formatOnType": true,
    "files.trimFinalNewlines": true,
  },
  // Plugin TODO Tree
  "todo-tree.highlights.defaultHighlight": {
    "foreground": "#2e872e",
    "type": "none",
  },
  "byesig.enabled": true,
  "byesig.fold": false,
  "byesig.opacity": 0.5,
  "byesig.showIcon": false,
  "rubyLsp.enabledFeatures": {
    "codeActions": true,
    "diagnostics": true,
    "documentHighlights": true,
    "documentLink": true,
    "documentSymbols": true,
    "foldingRanges": true,
    "formatting": true,
    "hover": true,
    "inlayHint": true,
    "onTypeFormatting": true,
    "selectionRanges": true,
    "semanticHighlighting": true,
    "completion": true,
    "codeLens": false,
  },
  // YAML Settings
  "yaml.format.singleQuote": false,
  "yaml.format.enable": true,
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  // JavaScript & ESLint
  "javascript.updateImportsOnFileMove.enabled": "always",
  "eslint.validate": [
    "typescript",
    "typescriptreact"
  ],
  "eslint.format.enable": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "update.showReleaseNotes": false,
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  },
  "github.copilot.editor.enableAutoCompletions": false,
  "rubyLsp.featureFlags": {
    "all": true,
  },
  "docker.extension.enableComposeLanguageServer": false,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "github.copilot.nextEditSuggestions.enabled": false,
  // Disable built-in AI / MCP features
  "chat.agent.enabled": false,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  },
  "chat.commandCenter.enabled": false,
  "svelte.enable-ts-plugin": true,
  "claudeCode.preferredLocation": "panel",
  "claudeCode.selectedModel": "default",
  "diffEditor.renderSideBySide": false,
  "chat.mcp.access": "none",
  "workbench.iconTheme": "material-icon-theme",
  "json.schemaDownload.trustedDomains": {
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://models.dev": true,
    "https://opencode.ai": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://www.schemastore.org/": true
  },
}
